# Copy this file to .env.production on the PHP server. Never commit real keys.
ZEKNOVA_AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=replace-with-server-side-key
DEEPSEEK_MODEL=deepseek-v4-flash

# Inactive fallback unless ZEKNOVA_AI_PROVIDER=openai.
OPENAI_API_KEY=replace-with-server-side-key
OPENAI_MODEL=gpt-5.6
